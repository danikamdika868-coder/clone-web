  margin: 0;
  background: linear-gradient(135deg, #2c2c54, #6c63ff);
  color: white;
  transition: 0.3s;
}

/* DARK MODE */
body.dark {
  background: #121212;
  color: #eee;
}

body.dark .container,
body.dark .skill-card,
